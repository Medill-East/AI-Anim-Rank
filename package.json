{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "node --experimental-strip-types scripts/build.ts",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --experimental-strip-types --test tests/rendered-html.test.mjs tests/pwa-assets.test.mjs tests/release-build.test.mjs tests/ranking.test.ts tests/ranking-workspace.test.ts tests/progress.test.ts tests/sync-crypto.test.ts tests/sync-client.test.ts tests/sync-vault.test.ts tests/sync-worker.test.ts && tsx --test tests/ranking-workspace-dom.test.tsx",
    "test:worker": "node --experimental-strip-types --test tests/sync-worker.test.ts",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "worker:migrate": "wrangler d1 migrations apply ai-anim-rank-sync --remote --config worker/wrangler.toml",
    "validate:data": "node --experimental-strip-types scripts/validate-ranking.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@scure/bip39": "^1.5.4",
    "@types/qrcode": "^1.5.6",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-loading-skeleton": "3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
